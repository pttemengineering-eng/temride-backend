# TemRide Backend — Environment Variables
# Copy this file to .env and fill in all values

# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/temride

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ────────────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_EXPIRES_IN=7d

# ─── Midtrans Payment Gateway ───────────────────────────────────────────────
MIDTRANS_SERVER_KEY=your_midtrans_server_key
MIDTRANS_CLIENT_KEY=your_midtrans_client_key
MIDTRANS_IS_PRODUCTION=false

# ─── Google Maps ────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=AIzaSyByPNavk7fyLZYjNwF2xb_nNAW0UhTa0IU

# ─── Fonnte WhatsApp ────────────────────────────────────────────────────────
FONNTE_API_KEY=your_fonnte_key

# ─── Firebase Cloud Messaging ───────────────────────────────────────────────
FCM_SERVER_KEY=your_fcm_server_key

# ─── Server ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Business Logic ─────────────────────────────────────────────────────────
PLATFORM_FEE_PERCENT=10
DRIVER_SHARE_PERCENT=90
BASE_FARE=5000
PRICE_PER_KM=2500
SURGE_MULTIPLIER_DEFAULT=1.0
ORDER_BROADCAST_RADIUS_KM=3
ORDER_ACCEPT_TIMEOUT_SECONDS=30

# ─── Voucher ────────────────────────────────────────────────────────────────
VOUCHER_EXPIRY_DAYS=30
